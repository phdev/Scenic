{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "s6 compress meta (two-profile)",
  "type": "object",
  "required": ["profiles", "primary_profile", "viewer_profile", "sog_tool"],
  "additionalProperties": true,
  "properties": {
    "sog_tool": {"type": "string"},
    "primary_profile": {"type": "string"},
    "viewer_profile": {"type": "string"},
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["in_count", "after_opacity_floor", "after_isolation_prune", "after_merge", "final_count", "stride_retries", "ply_bytes", "sog_bytes", "target", "cap"],
        "additionalProperties": true,
        "properties": {
          "in_count": {"type": "integer", "minimum": 0},
          "after_opacity_floor": {"type": "integer", "minimum": 0},
          "after_isolation_prune": {"type": "integer", "minimum": 0},
          "after_merge": {"type": "integer", "minimum": 0},
          "final_count": {"type": "integer", "minimum": 0},
          "stride_retries": {"type": "array", "items": {"type": "object"}},
          "ply_bytes": {"type": "integer", "minimum": 0},
          "sog_bytes": {"type": "integer", "minimum": 0},
          "target": {"type": "integer", "minimum": 0},
          "cap": {"type": "integer", "minimum": 0},
          "sog_max_mb": {"type": "number", "minimum": 0}
        }
      }
    }
  }
}
