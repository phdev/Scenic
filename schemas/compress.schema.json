    "after_opacity_floor": {"type": "integer", "minimum": 0},
    "after_isolation_prune": {"type": "integer", "minimum": 0},
    "after_merge": {"type": "integer", "minimum": 0},
    "final_count": {"type": "integer", "minimum": 0},
    "stride_retries": {"type": "array", "items": {"type": "object"}},
