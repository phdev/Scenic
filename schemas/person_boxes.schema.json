{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "s0 person detections across perspective views",
  "type": "object",
  "required": ["views", "total_hits"],
  "additionalProperties": false,
  "properties": {
    "total_hits": {"type": "integer", "minimum": 0},
    "views": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "yaw_deg", "pitch_deg", "fov_deg", "boxes"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "yaw_deg": {"type": "number"},
          "pitch_deg": {"type": "number"},
          "fov_deg": {"type": "number"},
          "boxes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["xyxy", "score"],
              "additionalProperties": false,
              "properties": {
                "xyxy": {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4},
                "score": {"type": "number", "minimum": 0, "maximum": 1}
              }
            }
          }
        }
      }
    }
  }
}
